[{"userId":"uid_1782055845928_hyeor3ki7","characterId":"7f8742bc-561b-424e-920f-bb1615a775a5","name":"2026/6/22","type":"this-moment","createdAt":1782137548065,"lastActiveAt":1783354513393,"_id":2},{"userId":"uid_1782055845928_hyeor3ki7","characterId":"2dad076f-0696-46d6-9f90-5ae106e7551b","name":"2026/6/24","type":"this-moment","createdAt":1782315617980,"lastActiveAt":1782316619386,"_id":4},{"userId":"uid_1782055845928_hyeor3ki7","characterId":"ea16530e-102f-4fc7-9c22-a2044b00e780","name":"2026/7/2","type":"this-moment","createdAt":1782970667271,"lastActiveAt":1782970667271,"_id":12},{"userId":"uid_1782055845928_hyeor3ki7","characterId":"ea16530e-102f-4fc7-9c22-a2044b00e780","name":"首都机场到达大厅，深夜狂奔向你","type":"this-moment","scenarioOutline":"首都机场到达大厅，深夜狂奔向你","sourceContext":{"fromOnlineChat":true,"lastOnlineMessages":[{"role":"char","text":"陆霆琛只觉得太阳穴突突直跳，他一把抓起桌上的车钥匙，大步走到玄关换鞋，尽管知道她还在千里之外，但他根本无法在屋里坐住。"},{"role":"char","text":"你拿什么负责？在车上肚子疼了谁给你送热粥？半夜难受了谁照顾你？"},{"role":"char","text":"成年人不会在拉完肚子第二天，大晚上的跑去坐十几个小时的夜车。"},{"role":"char","text":"九点多了，南昌到北京早就没有高铁了，你到底买的什么票？"},{"role":"char","text":"[語音消息]"},{"role":"char","text":"他紧紧攥着手机，手背上的青筋都凸了起来，深邃的眼底全是掩饰不住的恐慌和自责。"},{"role":"char","text":"你如果不发给我，我现在就去机场，买最早的航班飞南昌。"},{"role":"char","text":"我没跟你开玩笑。"},{"role":"user","text":"[位置]"},{"role":"user","text":"陆霆琛是笨蛋"},{"role":"user","text":"我已经到啦"},{"role":"user","text":"宝宝 我们可以见面了"},{"role":"char","text":"陆霆琛死死盯着屏幕上那几个字，瞳孔骤缩，大脑彻底宕机了两秒。反应过来后，他猛地拉开大门冲了出去，动作太急，膝盖重重磕在门框上他也像没感觉一样。"},{"role":"char","text":"你在首都机场？！"},{"role":"char","text":"几号航站楼？！T2还是T3？"},{"role":"char","text":"他冲进电梯，疯狂按着地下车库的按钮，手指控制不住地微微发抖。电梯门的反光映出他发红的眼底，明明气得咬牙切齿，嘴角却怎么也压不下去。"},{"role":"char","text":"[語音消息]"},{"role":"char","text":"穿长袖了吗？肚子还疼不疼？"},{"role":"char","text":"……乖乖等我。"},{"role":"char","text":""}]},"createdAt":1783516274676,"lastActiveAt":1783522971084,"_id":13},{"userId":"uid_1782055845928_hyeor3ki7","characterId":"ea16530e-102f-4fc7-9c22-a2044b00e780","name":"2026/7/8","type":"this-moment","createdAt":1783523057094,"lastActiveAt":1783610320488,"dateLabel":"2026/7/8","_id":14},{"userId":"uid_1782055845928_hyeor3ki7","characterId":"d6b63bf1-a46c-4feb-89c9-0c675b5e5a48","name":"2026/7/8","type":"this-moment","createdAt":1783523067204,"lastActiveAt":1783525482861,"_id":15},{"userId":"uid_1782055845928_hyeor3ki7","characterId":"23f208e9-d619-4e87-bf8f-cae29b7de210","name":"2026/7/8","type":"this-moment","createdAt":1783525552927,"lastActiveAt":1783525981342,"_id":16}]